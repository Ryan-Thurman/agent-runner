{
  "projectName": "agent-runner",
  "planName": "Review Contract Execution Plan",
  "planPath": "docs/plan-review-contract.md",
  "baseBranch": "main",
  "checks": [
    "python3 -m compileall -q .",
    "python3 -m unittest discover -s tests -v"
  ],
  "agents": {
    "claude": {
      "command": "claude",
      "promptArgs": ["-p"],
      "writeFlags": ["--permission-mode=acceptEdits", "--allowedTools=Bash(git:*),Bash(gh:*),Bash(python3:*)"],
      "readOnlyFlags": ["--disallowedTools=Edit,Write,NotebookEdit"],
      "promptPrefix": "use a sonnet 5 or opus agent for this PR. If its simple code never use the opus agent. Reserve opus for complex PR reviews",
      "outputCapture": "stdout"
    },
    "codex": {
      "command": "codex",
      "promptArgs": ["exec"],
      "writeFlags": ["--sandbox", "workspace-write", "-c", "sandbox_workspace_write.network_access=true"],
      "readOnlyFlags": ["--sandbox", "read-only", "-c", "sandbox_read_only.network_access=true"],
      "outputCapture": "last-message-file"
    },
    "antigravity": {
      "command": "agy",
      "promptArgs": ["--print-timeout", "40m", "--model", "Gemini 3.1 Pro (High)"],
      "writeFlags": ["--dangerously-skip-permissions", "-p"],
      "readOnlyFlags": ["--sandbox", "-p"],
      "outputCapture": "stdout"
    }
  },
  "roles": {
    "coder": "codex",
    "reviewer": "codex"
  },
  "roleFallbacks": {
    "reviewer": ["antigravity"]
  },
  "maxRetriesPerPhase": 3,
  "timeoutMinutes": 45,
  "autoCommit": true,
  "openPrWhenComplete": false,
  "allowDirty": false,
  "mergeOnClose": true,
  "mergeStrategy": "squash"
}
