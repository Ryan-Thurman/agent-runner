{
  "projectName": "agent-runner",
  "planName": "Agent Runner Build Plan",
  "planPath": "docs/plan.md",
  "baseBranch": "main",
  "checks": [
    "python3 -m compileall -q .",
    "python3 -m unittest discover -s tests -v"
  ],
  "agents": {
    "claude": {
      "command": "claude",
      "promptArgs": ["-p"],
      "writeFlags": ["--permission-mode", "acceptEdits"],
      "readOnlyFlags": ["--disallowedTools=Edit,Write,NotebookEdit"],
      "promptPrefix": "use a sonnet 5 or opus agent for this PR. If its simple code never use the opus agent. Reserve opus for complex PR reviews",
      "outputCapture": "stdout"
    },
    "codex": {
      "command": "codex",
      "promptArgs": ["exec"],
      "writeFlags": ["--sandbox", "workspace-write"],
      "readOnlyFlags": ["--sandbox", "read-only"],
      "outputCapture": "last-message-file"
    }
  },
  "roles": {
    "coder": "codex",
    "reviewer": "claude"
  },
  "maxRetriesPerPhase": 3,
  "timeoutMinutes": 45,
  "autoCommit": true,
  "openPrWhenComplete": false,
  "allowDirty": false
}
